generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  phone         String
  password      String
  role          Role            @default(PASSENGER)
  avatarUrl     String?
  isActive      Boolean         @default(true)
  crmNotes      Json            @default("[]")
  walletBalance Float           @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  bookings      Booking[]
  tickets       SupportTicket[]
  transactions  Transaction[]
  trips         Trip[]          @relation("DriverTrips")
  vehicles      Vehicle[]
  reviews       Review[]

  @@map("users")
}

model RolePermission {
  id          String   @id @default(uuid())
  role        Role     @unique
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("role_permissions")
}

model Vehicle {
  id          String                @id @default(uuid())
  model       String
  plateNumber String                @unique
  capacity    Int                   @default(14)
  driverId    String?
  type        String                @default("SHUTTLE_BUS")
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  locations   LiveVehicleLocation[]
  trips       Trip[]
  driver      User?                 @relation(fields: [driverId], references: [id])

  @@map("vehicles")
}

model Route {
  id                       String   @id @default(uuid())
  name                     String
  path                     Json
  coverImage               String?
  checkpoints              Json     @default("[]")
  distanceKm               Float    @default(0)
  estimatedDurationMinutes Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  trips                    Trip[]

  @@map("routes")
}

model Trip {
  id             String     @id @default(uuid())
  routeId        String
  vehicleId      String?
  driverId       String?
  departureTime  DateTime
  arrivalTime    DateTime?
  status         TripStatus @default(SCHEDULED)
  priceEGP       Float
  availableSeats Int
  bookedSeats    Int        @default(0)
  lockedSeats    Json       @default("[14]")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  bookings       Booking[]
  driver         User?      @relation("DriverTrips", fields: [driverId], references: [id])
  route          Route      @relation(fields: [routeId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?   @relation(fields: [vehicleId], references: [id])
  reviews        Review[]

  @@map("trips")
}

model Booking {
  id                  String        @id @default(uuid())
  userId              String
  tripId              String
  seatNumbers         Json
  pickupStopId        String?
  dropoffStopId       String?
  pickupCheckpoint    Json?
  dropoffCheckpoint   Json?
  status              BookingStatus @default(PENDING)
  paymentStatus       PaymentStatus @default(PENDING)
  paymobOrderId       Int?          @unique
  amountEGP           Float
  bookedAt            DateTime      @default(now())
  qrVerificationToken String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  trip                Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  review              Review?

  @@map("bookings")
}

model LiveVehicleLocation {
  id                String   @id @default(uuid())
  vehicleId         String
  driverId          String
  location          Json
  speedKmh          Float    @default(0)
  headingDegrees    Float    @default(0)
  batteryPercentage Float?
  status            String   @default("ACTIVE")
  lastUpdatedAt     DateTime @default(now())
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("live_vehicle_locations")
}

model SupportTicket {
  id        String   @id @default(uuid())
  userId    String
  name      String
  email     String
  phone     String
  subject   String
  message   String
  status    String   @default("OPEN")
  replies   Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

model Transaction {
  id              String        @id @default(uuid())
  bookingId       String?
  userId          String
  paymobOrderId   Int?
  amountEGP       Float
  status          PaymentStatus @default(PENDING)
  paymentMethod   String
  paymobPaymentId String?
  rawResponse     Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  booking         Booking?      @relation(fields: [bookingId], references: [id])
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

enum Role {
  PASSENGER
  DRIVER
  OWNER
  SUPER_ADMIN
  ADMIN
  OPERATION
}

enum TripStatus {
  SCHEDULED
  BOARDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  PENDING_PAYMENT
  CONFIRMED
  BOARDED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum StopType {
  START
  CHECKPOINT
  END
}

model ChatMessage {
  id         String   @id @default(uuid())
  ticketId   String
  senderId   String
  senderRole String
  senderName String
  message    String
  createdAt  DateTime @default(now())

  @@map("chat_messages")
}

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  userId    String
  tripId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Partner {
  id         String   @id @default(uuid())
  name       String
  logoUrl    String
  websiteUrl String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("partners")
}


