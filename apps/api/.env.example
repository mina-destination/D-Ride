# API Environment Variables — copy to .env
MONGODB_URI=mongodb://root:secret@localhost:27017/dride?authSource=admin
PORT=3000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_IFRAME_ID=
PAYMOB_INTEGRATION_ID=
REDIS_URL=redis://localhost:6379

# SMTP Email Notifications (e.g. Google Workspace)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_workspace_email@yourdomain.com
SMTP_PASS=your_google_app_password
SMTP_FROM="D-Ride <no-reply@yourdomain.com>"

# Google Sign-In Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here

