# ===========================================
# D-Ride Transport Platform — Environment
# ===========================================

# PostgreSQL
DATABASE_URL=postgresql://root:secret@localhost:5432/dride?schema=public

# Redis (required for WebSocket scaling and live tracking caching)
REDIS_URL=redis://localhost:6379

# NestJS API
PORT=3000
NODE_ENV=development

# CORS — Comma-separated list of allowed origins (required in production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d

# Paymob Payment Gateway
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_PUBLIC_KEY=your_paymob_public_key
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret
PAYMOB_IFRAME_ID=your_paymob_iframe_id
PAYMOB_INTEGRATION_ID=your_paymob_integration_id
PAYMOB_WALLET_INTEGRATION_ID=your_paymob_wallet_integration_id

# Twilio / SMS & WhatsApp Notification Gateway
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# SMTP Email Notifications (e.g. Google Workspace)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_workspace_email@yourdomain.com
SMTP_PASS=your_google_app_password
SMTP_FROM="D-Ride <no-reply@yourdomain.com>"

# Google Sign-In Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here

# OpenTelemetry Tracing (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=dride-api

# Configurable Defaults (optional)
DEFAULT_VEHICLE_CAPACITY=14
DEFAULT_COUNTRY_CODE=+20
DEFAULT_LOCKED_SEATS=[14]

