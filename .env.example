# ===========================================
# D-Ride Transport Platform — Environment
# ===========================================

# PostgreSQL
DATABASE_URL=postgresql://root:secret@localhost:5432/dride?schema=public

# NestJS API
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Paymob Payment Gateway
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_HMAC_SECRET=your_paymob_hmac_secret
PAYMOB_IFRAME_ID=your_paymob_iframe_id
PAYMOB_INTEGRATION_ID=your_paymob_integration_id
PAYMOB_WALLET_INTEGRATION_ID=your_paymob_wallet_integration_id

# Twilio / SMS Notification Gateway
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

